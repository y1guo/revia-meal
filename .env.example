# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Admin bootstrap — read only by scripts/seed-admin.ts on an empty users table.
# Ignored once at least one admin exists.
INITIAL_ADMIN_EMAIL=

# Dev-only: bypass Google OAuth on the login page and instead show a list of
# allowlisted users you can sign in as with one click. Hard-gated by
# NODE_ENV !== 'production', so this flag has no effect in a Vercel deploy.
# Leave unset outside of local development.
# DEV_AUTH_BYPASS=true
