# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — configured on the Supabase Auth provider side,
# but also referenced here for the `hd` domain-restrict hint on sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin bootstrap — read only by scripts/seed-admin.ts on an empty users table.
# Ignored once at least one admin exists.
INITIAL_ADMIN_EMAIL=

# Optional: restrict Google sign-in to this Workspace domain (e.g. heyrevia.com).
# Leave blank to accept any Google account present in the users allowlist.
GOOGLE_WORKSPACE_HD=
